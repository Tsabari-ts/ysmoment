# =====================================================================
# YsMoment Backend — Production Environment Variables
# Set these in your hosting provider dashboard (Render / Railway / etc.)
# NEVER commit real values to source control.
# =====================================================================

# PostgreSQL connection string (from Neon or Supabase)
ConnectionStrings__DefaultConnection=Host=your-host.neon.tech;Port=5432;Database=ysmoment;Username=postgres;Password=YOUR_STRONG_PASSWORD;SSL Mode=Require

# JWT — generate with: openssl rand -base64 48
Jwt__Key=YOUR_RANDOM_SECRET_AT_LEAST_32_CHARACTERS
Jwt__Issuer=YsMoment
Jwt__Audience=YsMoment

# Admin seed — used only once when the DB is empty
Admin__Username=admin
Admin__Password=YOUR_STRONG_ADMIN_PASSWORD

# Frontend URL (used in QR code generation)
App__GuestBaseUrl=https://your-frontend.vercel.app/e

# Cloudinary (free tier — https://cloudinary.com)
Cloudinary__CloudName=your-cloud-name
Cloudinary__ApiKey=your-api-key
Cloudinary__ApiSecret=your-api-secret
Cloudinary__Folder=ysmoment

# SMS4Free (https://www.sms4free.co.il) — order confirmation / ready / event-ended SMS
Sms4Free__Key=your-api-key
Sms4Free__User=your-sms4free-username
Sms4Free__Pass=your-sms4free-password
Sms4Free__Sender=your-approved-sender-name

# CORS — comma-separated list of allowed frontend origins
Cors__Origins__0=https://your-frontend.vercel.app

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:$PORT
